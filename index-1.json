rics, and traces from both your .NET services and the Julia process in one view.","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"CHYG7mkXkn"}],"key":"ZIsSP5j8G6"}],"key":"rv3kR9YeLW"},{"type":"listItem","spread":true,"position":{"start":{"line":157,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"children":[{"type":"text","value":"Service Discovery","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"f5jKPhdbBS"}],"key":"gSHp1Fijf9"},{"type":"text","value":":  Aspire automatically handles internal networking. Your .NET app can find the Julia service by its name (e.g., ","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"W7WHq8fMUV"},{"type":"link","url":"http://julia-api","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"children":[{"type":"text","value":"http://julia-api","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"RM3wyCgIz8"}],"urlSource":"http://julia-api","key":"Pr4rfjXrNT"},{"type":"text","value":") without manual port management.","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"cdT4UIbK9B"}],"key":"Rf1MAm1oks"}],"key":"SicqvIKO5F"}],"key":"ZpfOi5MSR1"},{"type":"heading","depth":2,"position":{"start":{"line":159,"column":1},"end":{"line":159,"column":1}},"children":[{"type":"text","value":"Java (Spring Boot): Enterprise Microservices","position":{"start":{"line":159,"column":1},"end":{"line":159,"column":1}},"key":"Oh4fmjXB5E"}],"identifier":"java-spring-boot-enterprise-microservices","label":"Java (Spring Boot): Enterprise Microservices","html_id":"java-spring-boot-enterprise-microservices","implicit":true,"key":"asaX0AYnwU"},{"type":"paragraph","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"children":[{"type":"text","value":"In the Java ecosystem, orchestration is typically handled by external tools rather than the framework itself.","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"key":"ukz3efBNgF"}],"key":"s5AAv87RMM"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":161,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":161,"column":1},"end":{"line":161,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The “Spring Boot” of .NET: While Spring Boot is often compared to Aspire, Spring Boot focuses on the application logic, whereas Aspire focuses on the connection between applications.","position":{"start":{"line":161,"column":1},"end":{"line":161,"column":1}},"key":"QFdWbKfh9o"}],"key":"jr2Eo9vTBx"}],"key":"Nn2wc05HBP"},{"type":"listItem","spread":true,"position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Orchestration Logic: To run Julia with Java, you would usually rely on Docker Compose or Kubernetes. Java does not have a native “AppHost” equivalent that manages the lifecycle of local executables as seamlessly as Aspire’s AddExecutable.","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"key":"fDM4N9iLYy"}],"key":"VVYXM5K3dP"}],"key":"K9JTaCISuD"},{"type":"listItem","spread":true,"position":{"start":{"line":163,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Deployment: Java is arguably more “mature” for complex, polyglot cloud environments, but it requires more manual configuration (YAML/Scripts) to achieve the same “F5” local dev experience that Aspire offers.","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"RjtdPbctCG"}],"key":"u9601bBohu"}],"key":"HfZ9R2KBOL"}],"key":"hIn8wy3Vuc"},{"type":"paragraph","position":{