rics, and traces from both your .NET services and the Julia process in one view.","position":{"start":{"line":156,"column":1},"end":{"line":156,"column":1}},"key":"acCUDyyfqS"}],"key":"jdY7OtW1Ae"}],"key":"RiJ2g0mGp9"},{"type":"listItem","spread":true,"position":{"start":{"line":157,"column":1},"end":{"line":158,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"children":[{"type":"text","value":"Service Discovery","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"QbMoHuF1am"}],"key":"Nx51Jwwfl9"},{"type":"text","value":":  Aspire automatically handles internal networking. Your .NET app can find the Julia service by its name (e.g., ","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"kcM77iZdeD"},{"type":"link","url":"http://julia-api","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"children":[{"type":"text","value":"http://julia-api","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"ZWWOMuTQwL"}],"urlSource":"http://julia-api","key":"PQ52NMSg5b"},{"type":"text","value":") without manual port management.","position":{"start":{"line":157,"column":1},"end":{"line":157,"column":1}},"key":"g1XG7yhC86"}],"key":"e9uTQcNM36"}],"key":"Np4RWyzuBT"}],"key":"zeXZBeCXpC"},{"type":"heading","depth":2,"position":{"start":{"line":159,"column":1},"end":{"line":159,"column":1}},"children":[{"type":"text","value":"Java (Spring Boot): Enterprise Microservices","position":{"start":{"line":159,"column":1},"end":{"line":159,"column":1}},"key":"axzr4AO0AG"}],"identifier":"java-spring-boot-enterprise-microservices","label":"Java (Spring Boot): Enterprise Microservices","html_id":"java-spring-boot-enterprise-microservices","implicit":true,"key":"GYbCExcz2N"},{"type":"paragraph","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"children":[{"type":"text","value":"In the Java ecosystem, orchestration is typically handled by external tools rather than the framework itself.","position":{"start":{"line":160,"column":1},"end":{"line":160,"column":1}},"key":"HlHEubnMgS"}],"key":"YOJwCsMnes"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":161,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":161,"column":1},"end":{"line":161,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The “Spring Boot” of .NET: While Spring Boot is often compared to Aspire, Spring Boot focuses on the application logic, whereas Aspire focuses on the connection between applications.","position":{"start":{"line":161,"column":1},"end":{"line":161,"column":1}},"key":"VtYs5kFAna"}],"key":"p2pDIkcke7"}],"key":"lRm47mSZVO"},{"type":"listItem","spread":true,"position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Orchestration Logic: To run Julia with Java, you would usually rely on Docker Compose or Kubernetes. Java does not have a native “AppHost” equivalent that manages the lifecycle of local executables as seamlessly as Aspire’s AddExecutable.","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"key":"gn8Qzl3fzW"}],"key":"FemySZQ9Yw"}],"key":"voqi5o1Aij"},{"type":"listItem","spread":true,"position":{"start":{"line":163,"column":1},"end":{"line":164,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Deployment: Java is arguably more “mature” for complex, polyglot cloud environments, but it requires more manual configuration (YAML/Scripts) to achieve the same “F5” local dev experience that Aspire offers.","position":{"start":{"line":163,"column":1},"end":{"line":163,"column":1}},"key":"AnIbdjwxEY"}],"key":"oolP8r67GF"}],"key":"TElrk2Jvjc"}],"key":"xf6c0jJPEr"},{"type":"paragraph","position":{