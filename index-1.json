xrS5"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":43,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Open Julia in the JuliaService folder.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"zJ2mHbpZqQ"}],"key":"fF3Jsypj8v"}],"key":"Zvvrc9TfYk"},{"type":"listItem","spread":true,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Install dependencies:","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"rMVDTdKIHW"}],"key":"uiAlwdvAZ3"}],"key":"gOyx0RP82i"}],"key":"AiO2nqMP1q"},{"type":"code","lang":"","value":"julia\nusing Pkg\nPkg.add([\"Oxygen\", \"HTTP\", \"JSON3\"])","position":{"start":{"line":45,"column":1},"end":{"line":49,"column":1}},"key":"OOccG5mStq"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":50,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":50,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Local Path: Ensure julia is in your System Environment Variables (Path) so the AppHost can execute the command.","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"pWoOz1vWj1"}],"key":"DUltQKLw1b"}],"key":"OBWaDyJG1r"},{"type":"listItem","spread":true,"position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Create the Julia Service\nIn your solution root, create a folder named JuliaService and add a file named app.jl.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"SE2NOxy1ra"}],"key":"uS4EIZmd9h"}],"key":"DaAUFIMhE6"}],"key":"QuofwEStFD"},{"type":"code","lang":"","value":"julia\n# JuliaService/app.jl\nusing Oxygen\nusing HTTP\nusing JSON3\n\n# Define a basic GET route\n@get \"/weather\" function(req::HTTP.Request)\n    # Mock data to match the Aspire weather example\n    data = [\n        Dict(\"date\" => \"2024-05-10\", \"temperatureC\" => 25, \"summary\" => \"Sunny\"),\n        Dict(\"date\" => \"2024-05-11\", \"temperatureC\" => 18, \"summary\" => \"Breezy\")\n    ]\n    return Dict(\"forecast\" => data)\nend\n\n# Start the server on the port Aspire will expect\n# 0.0.0.0 is required for containerization/orchestration\nserve(host=\"0.0.0.0\", port=8000)","position":{"start":{"line":55,"column":1},"end":{"line":75,"column":1}},"key":"z3iL9Yv5dx"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Configure the Aspire AppHost\nOpen your AppHost/Program.cs. This is where you tell .NET Aspire how to manage the Julia process.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"X9OhGZat1Z"}],"key":"vvrlA2Uquj"}],"key":"YmUOiHVyuX"}],"key":"ExCC2qVpxR"},{"type":"code","lang":"","value":"csharp\nvar builder = DistributedApplication.CreateBuilder(args);\n\n// 1. Define the Julia Resource\nvar juliaApi = builder.AddExecutable(\"julia-service\", \"julia\", \"JuliaService\", \"app.jl\")\n    .WithHttpEndpoint(port: 8000, targetPort: 8000, name: \"http\")\n    .WithEnvironment(\"JULIA_PROJECT\", \".\"); // Use the local project env\n\n// 2. Reference Julia in your C# API or Frontend\nbuilder.AddProject<Projects.ApiService>(\"apiservice\")\n    .WithReference(juliaApi);\n\nbuilder.AddProject<Projects.Web>(\"webfrontend\")\n    .WithReference(juliaApi)\n    .WithExternalHttpEndpoints();\n\nbuilder.Build().Run();","position":{"start":{"line":79,"column":1},"end":{"line":97,"column":1}},"key":"F7Uk6jSpEv"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Consume Julia from the C# Web Frontend\nIn the Aspire starter template, the Web project usually has a WeatherApiClient.cs. You can update it to point to your Julia service using the service name defined in the AppHost.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"TG5yo6cNOC"}],"key":"NOkXbBtWbG"}],"key":"sHbSNMm6Ds"}],"key":"gX7bOO8W1T"},{"type":"code","lang":"","value":"csharp\n// Web/WeatherApiClient.cs\npublic class WeatherApiClient(HttpClient httpClient)\n{\n    public async Task<WeatherForecast[]> GetWeatherAsync()\n    {\n        // \"julia-service\" matches the name in AppHost\n        var response = await httpClient.GetFromJsonAsync<JuliaResponse>(\"http://julia-service/weather\");\n        return response?.Forecast ?? [];\n    }\n}\n\npublic record JuliaResponse(WeatherForecast[] Forecast);","position":{"start":{"line":101,"column":1},"end":{"line":115,"column":1}},"key":"HQLZs5ryqc"},{"type":"heading","depth":1,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Why this approach?","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"N6Cng6UeAG"}],"identifier":"why-this-approach","label":"Why this approach?","html_id":"why-this-approach","implicit":true,"key":"GS0Rj7aZgZ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":118,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Service Discovery: Aspire automatically manages the internal URLs. Your C# code doesn’t need to know that Julia is on localhost:8000; it just asks for julia-service.","position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"key":"wdhfOaRbNH"}],"key":"dbYCUiG33G"}],"key":"V4DKFiFEKC"},{"type":"listItem","spread":true,"position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Unified Logs: When you run the Aspire Dashboard, you will see the Julia stdout logs side-by-side with your C# logs.","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"RpGm7BO9RO"}],"key":"HF8eLSWSb9"}],"key":"fdY5mqORp8"},{"type":"listItem","spread":true,"position":{"start":{"line":120,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Unified Logs: When you run the Aspire Dashboard, you will see the Julia stdout logs side-by-side with your C# logs.","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"emfQdOLeeS"}],"key":"HS091hyKRW"}],"key":"K514rNHkjZ"}],"key":"YvFwoQHTPe"},{"type":"heading","depth":1,"position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Create a Dockerfile","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"FdJhzNsX77"}],"identifier":"create-a-dockerfile","label":"Create a Dockerfile","html_id":"create-a-dockerfile","implicit":true,"key":"S5MRQG2Zff"},{"type":"paragraph","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"For the Julia service so it works in a deployed Aspire environment","posi