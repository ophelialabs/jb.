ine":38,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Ensure Julia is installed and added to your system PATH.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"k5b842ql31"}],"key":"XrIzioFKl7"}],"key":"fVHCmvVZzl"},{"type":"listItem","spread":true,"position":{"start":{"line":37,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Install the Julia extension for VS Code to debug your .jl files alongside your C# code.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"uHVw55HcrP"}],"key":"o8sjkQ6b5l"}],"key":"dpuKUhCsnB"}],"key":"JGVETOwbgm"},{"type":"heading","depth":1,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Code sample for Julia web framework Oxygen to use as your backend service","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"Dc2I34KLE7"}],"identifier":"code-sample-for-julia-web-framework-oxygen-to-use-as-your-backend-service","label":"Code sample for Julia web framework Oxygen to use as your backend service","html_id":"code-sample-for-julia-web-framework-oxygen-to-use-as-your-backend-service","implicit":true,"key":"G60b4eNc0V"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"strong","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"Important Prerequisites","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"J8N7tTmQE1"}],"key":"wQkAETjRdI"},{"type":"text","value":"\nTo make this work seamlessly, ensure your Julia environment is initialized:","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"fQLVYxFOyY"}],"key":"XqVg4Bf7Fv"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":43,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Open Julia in the JuliaService folder.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"xr4LqLJwHZ"}],"key":"P1055MVuTd"}],"key":"QUABRBY2NF"},{"type":"listItem","spread":true,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Install dependencies:","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"VrhkutrBUD"}],"key":"ffI1PpEMIb"}],"key":"xmsNy1ApMU"}],"key":"KpthzTTSD8"},{"type":"code","lang":"","value":"julia\nusing Pkg\nPkg.add([\"Oxygen\", \"HTTP\", \"JSON3\"])","position":{"start":{"line":45,"column":1},"end":{"line":49,"column":1}},"key":"oaGUu3zOTa"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":50,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":50,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Local Path: Ensure julia is in your System Environment Variables (Path) so the AppHost can execute the command.","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"zCC2SCXseC"}],"key":"ZjVShVWgEv"}],"key":"rT16lD5UxF"},{"type":"listItem","spread":true,"position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Create the Julia Service\nIn your solution root, create a folder named JuliaService and add a file named app.jl.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"IVZ5mz3Kfy"}],"key":"StyU7nUwm3"}],"key":"ARRTG3ybk6"}],"key":"vcRdRAWdPy"},{"type":"code","lang":"","value":"julia\n# JuliaService/app.jl\nusing Oxygen\nusing HTTP\nusing JSON3\n\n# Define a basic GET route\n@get \"/weather\" function(req::HTTP.Request)\n    # Mock data to match the Aspire weather example\n    data = [\n        Dict(\"date\" => \"2024-05-10\", \"temperatureC\" => 25, \"summary\" => \"Sunny\"),\n        Dict(\"date\" => \"2024-05-11\", \"temperatureC\" => 18, \"summary\" => \"Breezy\")\n    ]\n    return Dict(\"forecast\" => data)\nend\n\n# Start the server on the port Aspire will expect\n# 0.0.0.0 is required for containerization/orchestration\nserve(host=\"0.0.0.0\", port=8000)","position":{"start":{"line":55,"column":1},"end":{"line":75,"column":1}},"key":"bsoul40DhD"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Configure the Aspire AppHost\nOpen your AppHost/Program.cs. This is where you tell .NET Aspire how to manage the Julia process.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"nafagXFDhG"}],"key":"K7PNKRl90c"}],"key":"kQmaeXyHKx"}],"key":"ioxO23MPoh"},{"type":"code","lang":"","value":"csharp\nvar builder = DistributedApplication.CreateBuilder(args);\n\n// 1. Define the Julia Resource\nvar juliaApi = builder.AddExecutable(\"julia-service\", \"julia\", \"JuliaService\", \"app.jl\")\n    .WithHttpEndpoint(port: 8000, targetPort: 8000, name: \"http\")\n    .WithEnvironment(\"JULIA_PROJECT\", \".\"); // Use the local project env\n\n// 2. Reference Julia in your C# API or Frontend\nbuilder.AddProject<Projects.ApiService>(\"apiservice\")\n    .WithReference(juliaApi);\n\nbuilder.AddProject<Projects.Web>(\"webfrontend\")\n    .WithReference(juliaApi)\n    .WithExternalHttpEndpoints();\n\nbuilder.Build().Run();","position":{"start":{"line":79,"column":1},"end":{"line":97,"column":1}},"key":"vK3raYlZnK"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Consume Julia from the C# Web Frontend\nIn the Aspire starter template, the Web project usually has a WeatherApiClient.cs. You can update it to point to your Julia service using the service name defined in the AppHost.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"L3os5nKYgk"}],"key":"DAWDseHAnB"}],"key":"VwU0Rl8gKW"}],"key":"EvYvNrv7vg"},{"type":"code","lang":"","value":"csharp\n// Web/WeatherApiClient.cs\npublic class WeatherApiClient(HttpClient httpClient)\n{\n    public async Task<WeatherForecast[]> GetWeatherAsync()\n    {\n        // \"julia-service\" matches the name in AppHost\n        var response = await httpClient.GetFromJsonAsync<JuliaResponse>(\"http://julia-service/weather\");\n        return response?.Forecast ?? [];\n    }\n}\n\npublic record JuliaResponse(WeatherForecast[] Forecast);","position":{"start":{"line":101,"column":1},"end":{"line":115,"column":1}},"key":"Zb6HVPqjmQ"},{"type":"heading","depth":1,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Why this approach?","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"Rvz3GheN2Z"}],"identifier":"why-this-approach","label":"Why this approach?","html_id":"why-this-approach","implicit":true,"key":"QAEg3FUwMc"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":118,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Service Discovery: Aspire automatically manages the internal URLs. Your C# code doesn’t need to know that Julia is on localhost:8000; it just asks for julia-service.","position":{"start":{"line":118,"column":1},"end":{"line":118,"column":1}},"key":"hRNeFrdaQZ"}],"key":"V4a3dbzY5s"}],"key":"qDAQ0Nk5LJ"},{"type":"listItem","spread":true,"position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Unified Logs: When you run the Aspire Dashboard, you will see the Julia stdout logs side-by-side with your C# logs.","position":{"start":{"line":119,"column":1},"end":{"line":119,"column":1}},"key":"hZTD6cICPa"}],"key":"Wgl0eDGxcH"}],"key":"SsBGlzoeJL"},{"type":"listItem","spread":true,"position":{"start":{"line":120,"column":1},"end":{"line":121,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Unified Logs: When you run the Aspire Dashboard, you will see the Julia stdout logs side-by-side with your C# logs.","position":{"start":{"line":120,"column":1},"end":{"line":120,"column":1}},"key":"gQwPAaFUtI"}],"key":"YUoyKaKiCd"}],"key":"I859VwMQq7"}],"key":"KPlSo8RX7C"},{"type":"heading","depth":1,"position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"Create a Dockerfile","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"u6gLdcXodw"}],"identifier":"create-a-dockerfile","label":"Create a Dockerfile","html_id":"create-a-dockerfile","implicit":true,"key":"N5dWtOXFcv"},{"type":"paragraph","position":{"start":{"line":123,"column":1},"end":{"line":123,"column":1}},"children":[{"type":"text","value":"For the Julia service so it works in a deployed Aspire environment","posi