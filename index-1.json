e":"listItem","spread":true,"position":{"start":{"line":130,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"C++ (Dlib/P-Invoke): Dlib runs inside the same process as your .NET code. A memory leak or a segmentation fault in the C++ layer will take down your entire .NET AppDomain/Worker Process.","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"jtCRoghjFA"}],"key":"QqpSMyLbON"}],"key":"UjyJmbgoRs"}],"key":"Zxc00bL4li"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":132,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":132,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Comparison Table\nFeature\tJulia (Microservice)\tC++ (Dlib P-Invoke)\nInterop\tJSON/gRPC (High-level)\tP-Invoke/C-API (Low-level)\nComplexity\tLow (Standard HTTP calls)\tHigh (Data marshalling/Pointers)\nPerformance\tHigh (JIT Compiled)\tUltra-High (Native)\nCold Start\tSlower (Julia JIT overhead)\tInstant\nTooling\tAspire Dashboard (Logs/Traces)\tNative Debugger required","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"G0pzhHpq9s"}],"key":"V4RjFC72la"}],"key":"DcoC9qWovP"}],"key":"uNrVtH9glL"},{"type":"heading","depth":2,"position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"Why the “Aspire + Julia” approach is winning","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"U8M9QRsQ30"}],"identifier":"why-the-aspire-julia-approach-is-winning","label":"Why the “Aspire + Julia” approach is winning","html_id":"why-the-aspire-julia-approach-is-winning","implicit":true,"key":"ADMcGsEML0"},{"type":"paragraph","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"children":[{"type":"text","value":"Modern architecture favors “sidecars” or “microservices”. By using Aspire to orchestrate Julia:","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"key":"F4YcGrqRuJ"}],"key":"hgT0JGRz5Y"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":142,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"You can scale the Julia service independently (e.g., give the Julia container more RAM/CPU than the Web UI).","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"QtCIdtWbIl"}],"key":"ablWONUfdB"}],"key":"uoq0sHWD6d"},{"type":"listItem","spread":true,"position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"You get Observability: Aspire shows you the execution time of your Julia endpoints automatically in the dashboard.","position":{"start":{"line":143,"column":1},"end":{"line":143,"column":1}},"key":"hciIo7Llp9"}],"key":"ITXjDGcYru"}],"key":"BgWdbJEJGM"},{"type":"listItem","spread":true,"position":{"start":{"line":144,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Library Support: Julia’s DifferentialEquations.jl or Flux.jl (ML) are often more modern and easier to use than Dlib’s specialized C++ templates.","position":{"start":{"line":144,"column":1},"end":{"line":144,"column":1}},"key":"uZ6LTVaGIF"}],"key":"NASQSDTyhn"}],"key":"oypTdRY7Uv"}],"key":"qCewhSUVQf"},{"type":"heading","depth":1,"position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"children":[{"type":"text","value":"Summary","position":{"start":{"line":146,"column":1},"end":{"line":146,"column":1}},"key":"G2dXlRg71a"}],"identifier":"summary","label":"Summary","html_id":"summary","implicit":true,"key":"bE8g