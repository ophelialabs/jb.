ice and add a file named app.jl.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"JSEi9KIc3p"}],"key":"ndYpUGcSIJ"}],"key":"zy8PwBQeHY"}],"key":"PDOtF1C4ae"},{"type":"code","lang":"","value":"julia\n# JuliaService/app.jl\nusing Oxygen\nusing HTTP\nusing JSON3\n\n# Define a basic GET route\n@get \"/weather\" function(req::HTTP.Request)\n    # Mock data to match the Aspire weather example\n    data = [\n        Dict(\"date\" => \"2024-05-10\", \"temperatureC\" => 25, \"summary\" => \"Sunny\"),\n        Dict(\"date\" => \"2024-05-11\", \"temperatureC\" => 18, \"summary\" => \"Breezy\")\n    ]\n    return Dict(\"forecast\" => data)\nend\n\n# Start the server on the port Aspire will expect\n# 0.0.0.0 is required for containerization/orchestration\nserve(host=\"0.0.0.0\", port=8000)","position":{"start":{"line":55,"column":1},"end":{"line":75,"column":1}},"key":"LSjdjVQPDh"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Configure the Aspire AppHost\nOpen your AppHost/Program.cs. This is where you tell .NET Aspire how to manage the Julia process.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"Pa3KyKR0nF"}],"key":"B4CezSW5Mb"}],"key":"YULRbxlyhe"}],"key":"OZXc0CTGj6"},{"type":"code","lang":"","value":"csharp\nvar builder = DistributedApplication.CreateBuilder(args);\n\n// 1. Define the Julia Resource\nvar juliaApi = builder.AddExecutable(\"julia-service\", \"julia\", \"JuliaService\", \"app.jl\")\n    .WithHttpEndpoint(port: 8000, targetPort: 8000, name: \"http\")\n    .WithEnvironment(\"JULIA_PROJECT\", \".\"); // Use the local project env\n\n// 2. Reference Julia in your C# API or Frontend\nbuilder.AddProject<Projects.ApiService>(\"apiservice\")\n    .WithReference(juliaApi);\n\nbuilder.AddProject<Projects.Web>(\"webfrontend\")\n    .WithReference(juliaApi)\n    .WithExternalHttpEndpoints();\n\nbuilder.Build().Run();","position":{"start":{"line":79,"column":1},"end":{"line":97,"column":1}},"key":"Q8JV1UVshG"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Consume Julia from the C# Web Frontend\nIn the Aspire starter template, the Web project usually has a WeatherApiClient.cs. You can update it to point to your Julia service using the service name defined in the AppHost.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"rG7HyxnyiT"}],"key":"EMjJQ0uaVU"}],"key":"u89kx26VOr"}],"key":"RpBCefKwIv"},{"type":"code","lang":"","value":"csharp\n// Web/WeatherApiClient.cs\npublic class WeatherApiClient(HttpClient httpClient)\n{\n    public async Task<WeatherForecast[]> GetWeatherAsync()\n    {\n        // \"julia-service\" matches the name in AppHost\n        var response = await httpClient.GetFromJsonAsync<JuliaResponse>(\"http://julia-service/weather\");\n        return response?.Forecast ?? [];\n    }\n}\n\npublic record JuliaResponse(WeatherForecast[] Forecast);","position":{"start":{"line":101,"column":1},"end":{"line":115,"column":1}},"key":"GVUKeBMSRR"},{"type":"heading","depth":1,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Why this approach?","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"TI3LGKxgjZ"}],"identifier":"why-this-approach","label":"Why this approach?","html_id":"why-this-approach","implicit":true,"key":"D58n0QU5Jx"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":118,"column":