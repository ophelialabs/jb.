e":"listItem","spread":true,"position":{"start":{"line":130,"column":1},"end":{"line":131,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"C++ (Dlib/P-Invoke): Dlib runs inside the same process as your .NET code. A memory leak or a segmentation fault in the C++ layer will take down your entire .NET AppDomain/Worker Process.","position":{"start":{"line":130,"column":1},"end":{"line":130,"column":1}},"key":"sjJtGtpHnp"}],"key":"VsITz5WaJQ"}],"key":"bpXyM8KwD3"}],"key":"VNSRuYf4lZ"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":132,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":132,"column":1},"end":{"line":139,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Comparison Table\nFeature\tJulia (Microservice)\tC++ (Dlib P-Invoke)\nInterop\tJSON/gRPC (High-level)\tP-Invoke/C-API (Low-level)\nComplexity\tLow (Standard HTTP calls)\tHigh (Data marshalling/Pointers)\nPerformance\tHigh (JIT Compiled)\tUltra-High (Native)\nCold Start\tSlower (Julia JIT overhead)\tInstant\nTooling\tAspire Dashboard (Logs/Traces)\tNative Debugger required","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"n2glXQohlS"}],"key":"W9KO10DyBY"}],"key":"SpgueSi93Z"}],"key":"beVGFRQazI"},{"type":"heading","depth":2,"position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"Why the “Aspire + Julia” approach is winning","position":{"start":{"line":140,"column":1},"end":{"line":140,"column":1}},"key":"q3b8kaFszz"}],"identifier":"why-the-aspire-julia-approach-is-winning","label":"Why the “Aspire + Julia” approach is winning","html_id":"why-the-aspire-julia-approach-is-winning","implicit":true,"key":"XBo5Wh4k6J"},{"type":"paragraph","position":{"start":{"line":141,"column":1},"end":{"line":141,"column":1}},"children":[{"type":"text","value":"Modern architecture