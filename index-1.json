nie.jl or Oxygen.jl) orchestrated by the AppHost.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"kBmZpYR4FK"}],"key":"E3wfzqyred"}],"key":"Su25gfYDMU"}],"key":"vXKMCylVZp"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Add an Executable Resource: In your AppHost/Program.cs, use the AddExecutable method to start the Julia server alongside your .NET services.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"GTFB8pyCED"}],"key":"YrIdzjwPx3"}],"key":"rqi79Icgr6"}],"key":"oFdtfXnpAR"},{"type":"code","lang":"","value":"csharp\nvar juliaApi = builder.AddExecutable(\"julia-api\", \"julia\", \".\", \"main.jl\")\n                      .WithHttpEndpoint(port: 8000, name: \"http\")\n                      .WithEnvironment(\"JULIA_ENV\", \"dev\");\n\nbuilder.AddProject<Projects.MyWebFrontend>(\"webfrontend\")\n       .WithReference(juliaApi);","position":{"start":{"line":8,"column":1},"end":{"line":16,"column":1}},"key":"cHTaLEw139"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Containerize for Deployment: If you plan to deploy, use AddContainer to run a Julia Docker image.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"JNV60cd3ch"}],"key":"S9imonZTDb"}],"key":"cSvfqTAVeX"}],"key":"u4wFSMQeY7"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":20,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"sta