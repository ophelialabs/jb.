ine":38,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Ensure Julia is installed and added to your system PATH.","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"siImeJZ5SW"}],"key":"d3KKxQWtTb"}],"key":"q0ihx51K4a"},{"type":"listItem","spread":true,"position":{"start":{"line":37,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Install the Julia extension for VS Code to debug your .jl files alongside your C# code.","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"ZnhcsCm3IQ"}],"key":"nzhMRwQM3Z"}],"key":"DhBxzG1aWW"}],"key":"qcwBwgeru2"},{"type":"heading","depth":1,"position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"Code sample for Julia web framework Oxygen to use as your backend service","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"Hb9dNNpUoF"}],"identifier":"code-sample-for-julia-web-framework-oxygen-to-use-as-your-backend-service","label":"Code sample for Julia web framework Oxygen to use as your backend service","html_id":"code-sample-for-julia-web-framework-oxygen-to-use-as-your-backend-service","implicit":true,"key":"LxxnGOTofe"},{"type":"paragraph","position":{"start":{"line":41,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"strong","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"Important Prerequisites","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"C2OL9phyyz"}],"key":"Vs3ajZmu24"},{"type":"text","value":"\nTo make this work seamlessly, ensure your Julia environment is initialized:","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"YK0Ih9DOSS"}],"key":"UmYPPsPqKZ"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":43,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Open Julia in the JuliaService folder.","position":{"start":{"line":43,"column":1},"end":{"line":43,"column":1}},"key":"HBHTpH8uQk"}],"key":"MvVFS7Z6ju"}],"key":"IKW4zdub8b"},{"type":"listItem","spread":true,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Install dependencies:","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"eeicpZKcKe"}],"key":"logij9rXk1"}],"key":"kUyypU6lsb"}],"key":"ddKnFhfDV2"},{"type":"code","lang":"","value":"julia\nusing Pkg\nPkg.add([\"Oxygen\", \"HTTP\", \"JSON3\"])","position":{"start":{"line":45,"column":1},"end":{"line":49,"column":1}},"key":"lcTxsHtEw6"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":50,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":50,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"text","value":"Local Path: Ensure julia is in your System Environment Variables (Path) so the AppHost can execute the command.","position":{"start":{"line":50,"column":1},"end":{"line":50,"column":1}},"key":"NNxlsnvKh2"}],"key":"YP1zgf7xNz"}],"key":"TAI6OpvJTe"},{"type":"listItem","spread":true,"position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":53,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"Create the Julia Service\nIn your solution root, create a folder named JuliaService and add a file named app.jl.","position":{"start":{"line":53,"column":1},"end":{"line":53,"column":1}},"key":"cyphXZdNC5"}],"key":"rUlA69wGxy"}],"key":"ZGOEYK80ks"}],"key":"ovAZlyYYkd"},{"type":"code","lang":"","value":"julia\n# JuliaService/app.jl\nusing Oxygen\nusing HTTP\nusing JSON3\n\n# Define a basic GET route\n@get \"/weather\" function(req::HTTP.Request)\n    # Mock data to match the Aspire weather example\n    data = [\n        Dict(\"date\" => \"2024-05-10\", \"temperatureC\" => 25, \"summary\" => \"Sunny\"),\n        Dict(\"date\" => \"2024-05-11\", \"temperatureC\" => 18, \"summary\" => \"Breezy\")\n    ]\n    return Dict(\"forecast\" => data)\nend\n\n# Start the server on the port Aspire will expect\n# 0.0.0.0 is required for containerization/orchestration\nserve(host=\"0.0.0.0\", port=8000)","position":{"start":{"line":55,"column":1},"end":{"line":75,"column":1}},"key":"A5mMNbDPwV"},{"type":"list","ordered":true,"start":2,"spread":false,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":77,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Configure the Aspire AppHost\nOpen your AppHost/Program.cs. This is where you tell .NET Aspire how to manage the Julia process.","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"pTHskvb57g"}],"key":"uHO68aHTzZ"}],"key":"HOmYlyKf9o"}],"key":"RIAxKgiYIw"},{"type":"code","lang":"","value":"csharp\nvar builder = DistributedApplication.CreateBuilder(args);\n\n// 1. Define the Julia Resource\nvar juliaApi = builder.AddExecutable(\"julia-service\", \"julia\", \"JuliaService\", \"app.jl\")\n    .WithHttpEndpoint(port: 8000, targetPort: 8000, name: \"http\")\n    .WithEnvironment(\"JULIA_PROJECT\", \".\"); // Use the local project env\n\n// 2. Reference Julia in your C# API or Frontend\nbuilder.AddProject<Projects.ApiService>(\"apiservice\")\n    .WithReference(juliaApi);\n\nbuilder.AddProject<Projects.Web>(\"webfrontend\")\n    .WithReference(juliaApi)\n    .WithExternalHttpEndpoints();\n\nbuilder.Build().Run();","position":{"start":{"line":79,"column":1},"end":{"line":97,"column":1}},"key":"PuXnKqizmS"},{"type":"list","ordered":true,"start":3,"spread":false,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":99,"column":1},"end":{"line":100,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Consume Julia from the C# Web Frontend\nIn the Aspire starter template, the Web project usually has a WeatherApiClient.cs. You can update it to point to your Julia service using the service name defined in the AppHost.","position":{"start":{"line":99,"column":1},"end":{"line":99,"column":1}},"key":"ZIo5o5Rw0v"}],"key":"Jl8nw4ANgE"}],"key":"vGPYUw6liI"}],"key":"pMHJDY3gQE"},{"type":"code","lang":"","value":"csharp\n// Web/WeatherApiClient.cs\npublic class WeatherApiClient(HttpClient httpClient)\n{\n    public async Task<WeatherForecast[]> GetWeatherAsync()\n    {\n        // \"julia-service\" matches the name in AppHost\n        var response = await httpClient.GetFromJsonAsync<JuliaResponse>(\"http://julia-service/weather\");\n        return response?.Forecast ?? [];\n    }\n}\n\npublic record JuliaResponse(WeatherForecast[] Forecast);","position":{"start":{"line":101,"column":1},"end":{"line":115,"column":1}},"key":"GehDRonm2U"},{"type":"heading","depth":1,"position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"Why this approach?","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"zjqPBPi75f"}],"identifier":"why-this-approach","label":"Why this approach?","html_id":"why-this-approach","implicit":true,"key":"ZL6wbxTgjZ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":118,"column":