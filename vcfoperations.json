{"version":3,"kind":"Article","sha256":"888aa0d3de345eed2b61985c022077feaf512857e6c7429259d854162a34f2f4","slug":"vcfoperations","location":"/mv/pages/legacy/wiki-old/linux/pages/vcf/vcfoperations.md","dependencies":[],"frontmatter":{"numbering":{"title":{"offset":5}},"exports":[{"format":"md","filename":"vcfoperations.md","url":"/jb./build/vcfoperations-7774a527fc79bd2675939a0b0755acd2.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Pulling vSphere World Metrics from VCF Operations via API\nWriter: Brock Peterson\n","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"D8lFKar29v"},{"type":"link","url":"https://www.brockpeterson.com/","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Brock Peterson","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fBEWSGPbcJ"}],"urlSource":"https://www.brockpeterson.com/","key":"lproWVi9qH"},{"type":"text","value":"\nAug 18","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lN6EeKcLIf"}],"key":"rZWX7vrGCn"},{"type":"paragraph","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"vSphere World is a powerful construct in VCF Operations, I think of it as the bucket that contains everything.  For example, maybe you want to see the number of Clusters, ESXi Hosts, and VMs in your environment.  Those are just metrics on the vSphere World object, like this.","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"uy5ZfpU8pn"}],"key":"UFgzRmKy8u"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"FYU68DytYp"}],"key":"dztMCIivWN"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"You can pull these metrics from the VCF Operations API surface, here’s how.  Go to ","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"HDLfWnL8hi"},{"type":"link","url":"https://vcfoperationsfqdnhere/suite-api","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"https://​vcfoperationsfqdnhere​/suite​-api","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"OEENSGONo7"}],"urlSource":"https://vcfoperationsfqdnhere/suite-api","key":"IrXjqi0hfY"},{"type":"text","value":" and authenticate.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"UhD7A4o4NS"}],"key":"hHbIF0y52C"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Authenticating with the Aria Operations API\nWriter: Brock Peterson\nBrock Peterson\nOct 14, 2024","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"cUICbuk1YP"}],"key":"atsMSKNwnf"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"The Aria Operations API is a powerful way of interacting programatically with Operations.  There are several ways to authenticate with the API, let’s explore them here.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"Igd3rHkOQg"}],"key":"XljddPzwpm"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"First, the Operations API can be accessed at the following URL:  https://operations_ip_or_fqdn/suite-api","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"q4PcRHORPy"}],"key":"AZAG22Jxrh"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"The easiest way is local authentication via the Authorize button top right of the API home page, which you can do like this.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"IjEjMuqREu"}],"key":"rlFXqhpKwq"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"The Authorize button issues a POST /suite-api/api/auth/token/acquire and caches that Bearer Token for use within the Swagger UI.  Similar to generating a Bearer Token like this, see the Response Body at the bottom.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"ETh70TAxd8"}],"key":"O0aNCdr3om"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"IQ5FYghLyE"}],"key":"ltfzZ3aI3f"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"You could acquire your Bearer Token via an API tool like Postman as well, like this.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"ZuWBKrbehi"}],"key":"UJ64Md8BtF"},{"type":"paragraph","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"brImUPrj7N"}],"key":"k2XsdPUnS5"},{"type":"paragraph","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"children":[{"type":"text","value":"You can use this Bearer Token in the Authorization tab of all subsequent calls (at least until it expires).","position":{"start":{"line":39,"column":1},"end":{"line":39,"column":1}},"key":"imZRfpXcc6"}],"key":"FS7kvoBWTc"},{"type":"paragraph","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"If you’d like to use Basic Authentication you’ll have to enable it like this.  As you can see Basic Auth is currently disabled in my environment and thus my request is failing.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"i9WTBPwVUd"}],"key":"jag4OzOPIZ"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"I’ve adjusted basicAuthentication.enabled=true and cycled the API service via “service api restart” and retried. Repeat steps 1-5 on all other nodes in the vRealize Operations cluster.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"M6qDAPDAMx"}],"key":"Rr8NBTvp0j"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"children":[{"type":"text","value":"As you can see in the Response Body, we got a list of Super Metrics as desired.  The Operations API is very powerful, use it!","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"VdSV2aoXVP"}],"key":"ZXA4HXQn2b"},{"type":"paragraph","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":56,"column":1},"end":{"line":56,"column":1}},"key":"myXZzuGD0W"}],"key":"Kpf2TLNGhQ"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"There are other ways to do this, which we’ve discussed previously here.  Once authenticated, you’ll need the vSphere World ResourceId, which you can find via GET /api/resources with the ResourceKind of vSphere World.  My call looks like this.","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"DZqRIQX1wK"}],"key":"kA9ydUoL2S"},{"type":"paragraph","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":62,"column":1},"end":{"line":62,"column":1}},"key":"An4kp5v6cU"}],"key":"xN7wMxmKmw"},{"type":"paragraph","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"Scroll down and click Execute to run it, which will give you the associated Curl command as well.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"pKveqWgXm8"}],"key":"yJFjNrK8br"},{"type":"paragraph","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":68,"column":1},"end":{"line":68,"column":1}},"key":"OgG2Og9GbO"}],"key":"cXcRoFOMoR"},{"type":"paragraph","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"The identifier is at the bottom, this is what we’ll use to get the metrics we want from vSphere World, but first we need to determine the StatKeys, which I think of as the metrics themselves.  Do this with GET /api/resources/statkeys and your resourceId, mine looks like this.  Note: you can use the searchstring field if you know what you want, for example I might have used total here.","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"fw1nYgjsOJ"}],"key":"KjG7HhXhfC"},{"type":"paragraph","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"zuEwF4bl4g"}],"key":"zv7YG2y6NX"},{"type":"paragraph","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"We now have the StatKeys for the metrics we want:","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"ZR6iuTIa3G"}],"key":"ARyeJZzc09"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Clusters: summary|total_number_clusters","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"oUgDAUzJ0c"}],"key":"kxdCxthYQk"},{"type":"paragraph","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"ESXi Hosts: summary|total_number_hosts","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"fyiflETmjF"}],"key":"ifJdNMHqJY"},{"type":"paragraph","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"text","value":"VMs: summary|total_number_vms","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"eYxefWZ6BZ"}],"key":"sSkUpwxMkT"},{"type":"paragraph","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"children":[{"type":"text","value":"Now we can get the latest values for them by using GET /api/resources/stats/latest as follows.","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"C4jvfY8Xd8"}],"key":"n1L2fQPhRs"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"WQXJLcMuV5"}],"key":"KRgpnYwONq"},{"type":"paragraph","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"children":[{"type":"text","value":"Notice I provided the resourceId for vSphere World and the statKeys we previously captured.","position":{"start":{"line":92,"column":1},"end":{"line":92,"column":1}},"key":"MginGPIlSs"}],"key":"wHBq4J7Shb"},{"type":"paragraph","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":95,"column":1},"end":{"line":95,"column":1}},"key":"VaJOdqnV9r"}],"key":"AuoxOsA2CX"},{"type":"paragraph","position":{"start":{"line":98,"column":1},"end":{"line":98,"column":1}},"children":[{"type":"text","value":"Click Execute and you’ll be given the latest values (along with the Curl command if you wany to use that elsewhere).","position":{"start":{"line":98,"column":1},"end":{"line":98,"column":1}},"key":"cPdPnKPNKX"}],"key":"GOvqpEQQC0"},{"type":"paragraph","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":101,"column":1},"end":{"line":101,"column":1}},"key":"BxqX2qNJgc"}],"key":"KMxLzopz25"},{"type":"paragraph","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"children":[{"type":"text","value":"Now if you compare these to the latest values in the UI, they match!","position":{"start":{"line":104,"column":1},"end":{"line":104,"column":1}},"key":"U5X2q3ev0c"}],"key":"no8TTqZiBP"},{"type":"paragraph","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"children":[{"type":"text","value":"ree","position":{"start":{"line":107,"column":1},"end":{"line":107,"column":1}},"key":"NQdYIan7Mp"}],"key":"L3RLSEAsSR"},{"type":"paragraph","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"children":[{"type":"text","value":"This same methodology can be used to pull metrics/properties against any object you want.  Use the VCF Operations API, it’s powerful!","position":{"start":{"line":110,"column":1},"end":{"line":110,"column":1}},"key":"aN2z0K6h1E"}],"key":"UEsMuTUEqZ"}],"key":"scShjwdWuP"}],"key":"Ku2E5pG37j"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"RHEL9 Docs","url":"/readme-50","group":"Linux"},"next":{"title":"README","url":"/readme-51","group":"Ophelia"}}},"domain":"http://localhost:3000"}