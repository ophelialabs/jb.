AIdrQOQzh"},{"type":"heading","depth":3,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Delta","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"xcNVfPabcG"}],"identifier":"delta","label":"Delta","html_id":"delta","implicit":true,"key":"VCdwgOB0GJ"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Following the Challenger shuttle disaster in 1986, President Reagan announced that the Space Shuttle would carry no more commercial payloads. To fill this gap, the Delta II was built by Boeing (1989) to launch medium-sized NASA payloads and small commercial payloads. The Delta III includes a larger fairing, larger strap-on motors, and a cryogenic second stage. The Delta IV line of medium-to-heavy launch vehicles is Boeing’s most advanced product in the Evolved Expendable Launch Vehicle (EELV) program. The Delta IV Heavy is capable of delivering a payload directly to GEO orbit.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"Jg5kq2LxQN"}],"key":"vGAJ7no1gY"},{"type":"heading","depth":3,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Pegasus","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"kMRQo9TgZT"}],"identifier":"pegasus","label":"Pegasus","html_id":"pegasus","implicit":true,"key":"tddmbNkfRc"},{"type":"heading","depth":3,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Space Shuttle","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"R9BxOqn6IH"}],"identifier":"space-shuttle","label":"Space Shuttle","html_id":"space-shuttle","implicit":true,"key":"zpFkoOdHOW"},{"type":"heading","depth":3,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","valu