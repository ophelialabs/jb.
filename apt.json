sition":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"HvUz0Y1BjE"}],"identifier":"system-wide-access-all-users","label":"System-Wide Access (All Users)","html_id":"system-wide-access-all-users","implicit":true,"key":"jaAiUA4btV"},{"type":"paragraph","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"If you want every user on the system to have access to APT, you can create a symlink in a standard system directory like /usr/local/bin, which is already in the system PATH","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"p9iNfyAwvK"}],"key":"CPQcmxLeZR"},{"type":"code","lang":"","value":"bash\nsudo ln -s /[full_path_to_apt_folder]/APT /usr/local/bin/APT","position":{"start":{"line":83,"column":1},"end":{"line":86,"column":1}},"key":"q2xAP7p8Dw"},{"type":"heading","depth":1,"position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"APT Wrapper & Auto-Updater Script","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"key":"pCVqPWuqpX"}],"identifier":"apt-wrapper-auto-updater-script","label":"APT Wrapper & Auto-Updater Script","html_id":"apt-wrapper-auto-updater-script","implicit":true,"key":"x2Z4HOsIvP"},{"type":"paragraph","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"To manage the Astronomer’s Proposal Tool (APT) efficiently, you can use a wrapper script. Because APT is a standalone ","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"oKBFGbZZtK"},{"type":"strong","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"Java","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"QZKNt6SBol"}],"key":"wI9SFM35ML"},{"type":"text","value":"-based application installed via a ","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"nfOCdEh0HB"},{"type":"strong","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"Shell","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"RjTQLK1wJU"}],"key":"F9wOBp9iIX"},{"type":"text","value":" script rather than a standard package manager (like apt-get), “updating” typically involves re-running the latest installer from ","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"ljUh0atxgN"},{"type":"link","url":"https://www.stsci.edu/scientific-community/software/astronomers-proposal-tool-apt/linux","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"children":[{"type":"text","value":"STSci","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"nhDT7J4Dpl"}],"urlSource":"https://www.stsci.edu/scientific-community/software/astronomers-proposal-tool-apt/linux","key":"J4Lijd9Grr"},{"type":"text","value":".","position":{"start":{"line":89,"column":1},"end":{"line":89,"column":1}},"key":"Q9J9kC9B3I"}],"key":"UpJrUB9jgn"},{"type":"paragraph","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"children":[{"type":"text","value":"The following script checks for a new version of the installer, downloads it if necessary, and then launches the application.","position":{"start":{"line":91,"column":1},"end":{"line":91,"column":1}},"key":"x5MOhXkKx0"}],"key":"pgSFBWl8FZ"},{"type":"paragraph","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"children":[{"type":"text","value":"Save this code as run_apt.sh","position":{"start":{"line":93,"column":1},"end":{"line":93,"column":1}},"key":"SJGk2sKnfa"}],"key":"MWeU40mqIM"},{"type":"code","lang":"","value":"bash\n#!/bin/bash\n\n# --- CONFIGURATION ---\n# Path wher you want APT installed\nAPT_DIR=\"$HOME/APT\"\n# URL for the latest Linux installer (Check STScI for the most current link)\nINSTALLER_URL=\"https://apst.stsci.edu\"\nINSTALLER_NAME=\"install-linux-apt.sh\"\n\n# 1. CHECK FOR UPDATES\necho \"Checking for APT updates...\"\n# Download the latest installer script to a temporary location\ncurl -s -O $INSTALLER_URL\n\n# Compare with existing installer if it exists to see if there's a change\nif [ -f \"$APT_DIR/$INSTALLER_NAME\" ]; then\n    if cmp -s \"$INSTALLER_NAME\" \"$APT_DIR/$INSTALLER_NAME\"; then\n        echo \"APT is already up to date.\"\n        rm \"$INSTALLER_NAME\"\n    else\n        echo \"New version found. Installing...\"\n        sh \"$INSTALLER_NAME\" -q -dir \"$APT_DIR\"\n        mv \"$INSTALLER_NAME\" \"$APT_DIR/$INSTALLER_NAME\"\n    fi\nelse\n    echo \"APT not found. Performing first-time installation...\"\n    mkdir -p \"$APT_DIR\"\n    sh \"$INSTALLER_NAME\" -q -dir \"$APT_DIR\"\n    mv \"$INSTALLER_NAME\" \"$APT_DIR/$INSTALLER_NAME\"\nfi\n\n# 2. EXECUTION\necho \"Launching Astronomer's Proposal Tool...\"\nif [ -f \"$APT_DIR/APT\" ]; then\n    \"$APT_DIR/APT\" \"$@\"\nelse\n    echo \"Error: APT executable not found in $APT_DIR\"\n    exit 1\nfi\n\n# 3. Make it Executable\nchmod +x run_apt.sh\n\n# 4. Move to your PATH\nmkdir -p ~/bin\nmv run_apt.sh ~/bin/apt-tool\n# Ensure ~/bin is in your PATH (see previous instructions)","position":{"start":{"line":94,"column":1},"end":{"line":143,"column":1}},"key":"BXefwmXKwy"},{"type":"paragraph","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"text","value":"Now simply type apt-tool in your terminal. The script will handle checking for a newer installer before launching the GUI.","position":{"start":{"line":145,"column":1},"end":{"line":145,"column":1}},"key":"mrZdxnXHws"}],"key":"Q9SqWxceQx"},{"type":"heading","depth":1,"position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"children":[{"type":"text","value":"Now Create a Unified Wrapper Script","position":{"start":{"line":147,"column":1},"end":{"line":147,"column":1}},"key":"zwsdOt3usm"}],"identifier":"now-create-a-unified-wrapper-script","label":"Now Create a Unified Wrapper Script","html_id":"now-create-a-unified-wrapper-script","implicit":true,"key":"wUjS3jEHRb"},{"type":"paragraph","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"children":[{"type":"text","value":"This script will check for the latest installer from [STSci], update if needed, create a one-click launcher and then launch the app. You will need two files: a bash script to handle the logic and a .desktop file to create the icon.","position":{"start":{"line":148,"column":1},"end":{"line":148,"column":1}},"key":"ERPAxtC2ME"}],"key":"lVD1ijmWHD"},{"type":"heading","depth":1,"position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"children":[{"type":"text","value":"Replace this with cat EOF","position":{"start":{"line":149,"column":1},"end":{"line":149,"column":1}},"key":"f4oaBG7csl"}],"identifier":"replace-this-with-cat-eof","label":"Replace this with cat EOF","html_id":"replace-this-with-cat-eof","implicit":true,"key":"oj2fS7cgyO"},{"type":"code","lang":"","value":"bash\n# Create the file in a stable folder (e.g., ~/bin/ or ~/APT/):\n#!/bin/bash\n# Configuration\nAPT_DIR=\"$HOME/APT\"\nINSTALLER_URL=\"https://apst.stsci.edu\"\nINSTALLER_NAME=\"install-linux-apt.sh\"\n\nmkdir -p \"$APT_DIR\"\ncd \"$APT_DIR\"\n\n# 1. Update Check\necho \"Checking for updates...\"\ncurl -s -O $INSTALLER_URL\nif [ ! -f \"APT\" ] || ! cmp -s \"$INSTALLER_NAME\" \"last_installer.sh\"; then\n    echo \"New version found. Installing...\"\n    sh \"$INSTALLER_NAME\" -q -dir \"$APT_DIR\"\n    mv \"$INSTALLER_NAME\" \"last_installer.sh\"\nelse\n    echo \"APT is up to date.\"\n    rm \"$INSTALLER_NAME\"\nfi\n\n# 2. Launch\necho \"Launching APT...\"\n./APT \"$@\"\n\n# 3. Make it executable\nchmod +x ~/APT/apt_manager.sh\n\n# 4. Create the Desktop Icon\n# You must create a .desktop file to tell your Linux environment how to display and run the script.\n\n# Again, replace with cat\nnano ~/Desktop/APT.desktop\n\n# Paste the following (replace [your-user] with your actual username which you can find by typing whoami in the terminal.)*:\nini\n[Desktop Entry]\nVersion=1.0\nType=Application\nName=Astronomer Tool\nComment=Update and Launch APT\nExec=/home/[your-user]/APT/apt_manager.sh\nIcon=utilities-terminal\nTerminal=true\nCategories=Science;Astronomy;","position":{"start":{"line":150,"column":1},"end":{"line":198,"column":1}},"key":"OKQEy3RBwV"},{"type":"paragraph","position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"children":[{"type":"text","value":"If you don’t already have a high-resolution logo, you can download the official Space Telescope Science Institute (STScI) logo to your APT directory:","position":{"start":{"line":199,"column":1},"end":{"line":199,"column":1}},"key":"GLDyCzsUiK"}],"key":"G5LmtOdWsu"},{"type":"code","lang":"","value":"# 1. Download the STScI logo to your APT folder\nwget -O ~/APT/apt_icon.png https://upload.wikimedia.org\n\n# 2. Update Your .desktop File \nnano ~/Desktop/APT.desktop\n\n# 3. Update the Icon line\nIcon=/home/[your-user]/APT/apt_icon.png\n\n# 4. Move to Applications Menu\n# Either ask user or make it auto\ncp ~/Desktop/APT.desktop ~/.local/share/applications/","position":{"start":{"line":201,"column":1},"end":{"line":214,"column":1}},"key":"AZPwroGu0U"},{"type":"paragraph","position":{"start":{"line":216,"column":1},"end":{"line":216,"column":1}},"children":[{"type":"text","value":"This updated script now verifies the presence of the icon and retrieves it from the STScI Media assets if it’s missing.","position":{"start":{"line":216,"column":1},"end":{"line":216,"column":1}},"key":"UXrsw2ElHy"}],"key":"K3BNQ3GT31"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":217,"column":1},"end":{"line":218,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":217,"column":1},"end":{"line":218,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Updated apt_manager.sh\nUpdate your ~/APT/apt_manager.sh with this code:","position":{"start":{"line":217,"column":1},"end":{"line":217,"column":1}},"key":"ze5bwnZ74H"}],"key":"F2bok9MRyT"}],"key":"bJ0N4havSK"}],"key":"RYlkz4LPwZ"},{"type":"code","lang":"","value":"#!/bin/bash\n# Configuration\nAPT_DIR=\"$HOME/APT\"\nICON_PATH=\"$APT_DIR/apt_icon.png\"\nICON_URL=\"https://upload.wikimedia.org\"\nINSTALLER_URL=\"https://apst.stsci.edu\"\nINSTALLER_NAME=\"install-linux-apt.sh\"\n\nmkdir -p \"$APT_DIR\"\ncd \"$APT_DIR\"\n\n# 1. ICON CHECK\nif [ ! -f \"$ICON_PATH\" ]; then\n    echo \"Icon missing. Downloading from STScI assets...\"\n    curl -s -L -o \"$ICON_PATH\" \"$ICON_URL\"\nfi\n\n# 2. UPDATE CHECK\necho \"Checking for APT updates...\"\ncurl -s -O $INSTALLER_URL\nif [ ! -f \"APT\" ] || ! cmp -s \"$INSTALLER_NAME\" \"last_installer.sh\"; then\n    echo \"New version found. Installing...\"\n    sh \"$INSTALLER_NAME\" -q -dir \"$APT_DIR\"\n    mv \"$INSTALLER_NAME\" \"last_installer.sh\"\nelse\n    echo \"APT is up to date.\"\n    rm \"$INSTALLER_NAME\"\nfi\n\n# 3. LAUNCH\necho \"Launching APT...\"\n./APT \"$@\"\n\n# 4. Verify the Desktop Entry\nEnsure your ~/Desktop/APT.desktop file points to that specific path:\nIcon=/home/YOUR_USER/APT/apt_icon.png\n\n# 5. update the placeholder in your desktop file with your current Linux username\nsed -i \"s/\\[your-user\\]/$USER/g\" ~/Desktop/APT.desktop\n\n# 6. Refresh Gnome Desktop Shell\nupdate-desktop-database ~/.local/share/applications/","position":{"start":{"line":219,"column":1},"end":{"line":262,"column":1}},"key":"Gs37ZzHZaH"},{"type":"paragraph","position":{"start":{"line":264,"column":1},"end":{"line":264,"column":1}},"children":[{"type":"strong","position":{"start":{"line":264,"column":1},"end":{"line":264,"column":1}},"children":[{"type":"text","value":"The final .desktop file","position":{"start":{"line":264,"column":1},"end":{"line":264,"column":1}},"key":"ZGyrvqgmCc"}],"key":"SUei2nqa73"}],"key":"MI6XS9Xjrt"},{"type":"code","lang":"","value":"[Desktop Entry]\nVersion=1.0\nType=Application\nName=Astronomer Tool\nComment=Update and Launch APT\nExec=/home/[your-user]/APT/apt_manager.sh\nIcon=/home/[your-user]/APT/apt_icon.png\nTerminal=true\nCategories=Science;Astronomy;","position":{"start":{"line":265,"column":1},"end":{"line":275,"column":1}},"key":"EJoVzXtME8"}],"key":"yVzGxiHU1U"}],"key":"M7DrN7M7Gj"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"List Overview","url":"/index-8","group":"Space"},"next":{"title":"Tomorrow will add scix, doe, etc to the journals and will have to visit domains individually until complete","url":"/readme-15","group":"Journals"}}},"domain":"http://localhost:3000"}