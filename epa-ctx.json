{"version":3,"kind":"Article","sha256":"62d7d47ad21231a5f033dc9729ec3ff5ed4083806e72c234a3022b3bb6f1cb09","slug":"epa-ctx","location":"/mv/pages/legacy/site-old/Research/Periodic_table/CS/ElementData/epa_ctx.md","dependencies":[],"frontmatter":{"title":"Start an instance of the Exposure class","content_includes_title":true,"numbering":{"title":{"offset":5}},"exports":[{"format":"md","filename":"epa_ctx.md","url":"/jb./build/epa_ctx-5cddc92232d7b42d364566ae209a9e2b.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"A practical example of using the EPA’s Computational Toxicology and Exposure (CTX) API is to programmatically retrieve the toxicity data (ToxCast bioactivity) for a specific chemical using its standard EPA identifier, the DSSTox Substance ID (DTXSID).\nThis example uses Python to send an HTTP GET request to the API, retrieve the data in JSON format, and then processes it. The EPA also provides a Python library called ctx-python which simplifies this process, as shown in the snippets below.\nExample 1: Using ctx-python Library\nThis approach is highly recommended by the EPA as it handles the API calls and data processing for you.\npython\nimport ctxpy as ctx","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"q3rNkYnWQN"}],"key":"M2Ouzx8Jar"},{"type":"heading","depth":1,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Start an instance of the Exposure class","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"RO9EU9u0ag"}],"identifier":"start-an-instance-of-the-exposure-class","label":"Start an instance of the Exposure class","html_id":"start-an-instance-of-the-exposure-class","implicit":true,"key":"kM6y2OT9rJ"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"expo = ctx.Exposure()","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"HqEt3L5vlZ"}],"key":"nYjp5TiKMn"},{"type":"heading","depth":1,"position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"Retrieve data for Bisphenol A (DTXSID7020182) from the Chemical and Products Database (CPDat)","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"CYRMv6JVr6"}],"identifier":"retrieve-data-for-bisphenol-a-dtxsid7020182-from-the-chemical-and-products-database-cpdat","label":"Retrieve data for Bisphenol A (DTXSID7020182) from the Chemical and Products Database (CPDat)","html_id":"retrieve-data-for-bisphenol-a-dtxsid7020182-from-the-chemical-and-products-database-cpdat","implicit":true,"key":"KxEbuQZduh"},{"type":"heading","depth":1,"position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"‘puc’ stands for Product Use Categories","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"AKaY8MyHg5"}],"identifier":"puc-stands-for-product-use-categories","label":"‘puc’ stands for Product Use Categories","html_id":"puc-stands-for-product-use-categories","implicit":true,"key":"eHOnT6iY2S"},{"type":"paragraph","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"result = expo.search_cpdat(vocab_name=‘puc’, dtxsid=‘DTXSID7020182’)","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ewl7FLaZkc"}],"key":"s7jELuDtlS"},{"type":"heading","depth":1,"position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Print the retrieved data","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"jV2EsuKA3g"}],"identifier":"print-the-retrieved-data","label":"Print the retrieved data","html_id":"print-the-retrieved-data","implicit":true,"key":"t7MlRTLS7v"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"print(result)\nUse code with caution.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"wgpg8Hsmbh"}],"key":"Mkpwip6Gh3"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Example 2: Using Raw HTTP Request (for a single chemical’s details)\nIf you are not using Python or prefer raw API calls, you can make a standard HTTP GET request. This example retrieves basic chemical identifiers for Toluene.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"bq66a1TYBl"}],"key":"AFRxtfJpzF"}],"key":"lYgkPVuXCD"}],"key":"SyBqB0Vs0a"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Elementdata","url":"/elementdata","group":"Research"},"next":{"title":"Pubchem","url":"/pubchem","group":"Research"}}},"domain":"http://localhost:3000"}